generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum Role {
  ADMIN_GENERAL
  ADMIN_GROUP
  USER
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)

  otp       String?
  otpExpire DateTime?

  // 🔔 AJOUT (NE CASSE RIEN)
  pushToken String?

  createdAt DateTime @default(now())
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   String
  receiverId String
  content    String
  seen       Boolean  @default(false)
  createdAt  DateTime @default(now())
}